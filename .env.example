# voice_rag_agents environment template — placeholders only, never commit real secrets.
# Copy to .env and fill in as needed. Tests must NOT require any of these.

# Runtime profile: mock | local | integration | production-local
VOICE_RAG_PROFILE=mock

# Retrieval
VOICE_RAG_TOP_K=5
VOICE_RAG_CHUNK_SIZE_TOKENS=500
VOICE_RAG_CHUNK_OVERLAP_TOKENS=75

# Collection
VOICE_RAG_COLLECTION=voice_rag_chunks

# Embedding (NVIDIA Llama Nemotron Embed VL 1B V2 via OpenAI-compatible endpoint)
VOICE_RAG_EMBEDDING_BASE_URL=
VOICE_RAG_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
VOICE_RAG_EMBEDDING_DIM=2048
VOICE_RAG_EMBEDDING_API_KEY=

# LLM (Ollama / OpenAI-compatible)
VOICE_RAG_LLM_BASE_URL=http://localhost:11434/v1
VOICE_RAG_LLM_MODEL=llama3.1
VOICE_RAG_LLM_API_KEY=

# Milvus
VOICE_RAG_MILVUS_URI=http://localhost:19530

# STT (Whisper.cpp / Cipher / compatible)
VOICE_RAG_STT_PROVIDER=mock
VOICE_RAG_STT_COMMAND=
VOICE_RAG_STT_CONFIDENCE_THRESHOLD=0.5

# Files / safety
VOICE_RAG_INPUT_DIR=./data/input
VOICE_RAG_MAX_FILE_MB=25
